# =============================================================================
# Doc Parser API — Environment Variables
#
# Copy to .env and adjust as needed:
#   cp .env.example .env
#
# All variables are optional. Values below are the defaults.
# =============================================================================

# --- GPU / Device ---
# Auto-detects if omitted. Set "false" to force CPU.
# DOC_PARSER_USE_GPU=true

# --- OCR Engine ---
# "doctr" (deep learning, requires GPU) or "tesseract" (LSTM, CPU)
# DOC_PARSER_OCR_ENGINE=doctr

# --- OCR Settings ---
# DPI for PDF to image conversion (higher = better quality, slower)
# DOC_PARSER_OCR_DPI=350

# Batch size for docTR (adjust according to available VRAM)
# 20 = good for 20GB VRAM, reduce if OOM
# DOC_PARSER_OCR_BATCH_SIZE=20

# Minimum confidence to accept OCR result (0.0 to 1.0)
# Can be overridden per request via ?min_confidence=
# DOC_PARSER_MIN_CONFIDENCE=0.3

# --- OCR Orientation (docTR) ---
# For scanned documents with rotation/skew, try:
#   ASSUME_STRAIGHT_PAGES=false, DETECT_ORIENTATION=true, STRAIGHTEN_PAGES=true
# This improves accuracy but is slower.
# DOC_PARSER_ASSUME_STRAIGHT_PAGES=true
# DOC_PARSER_DETECT_ORIENTATION=false
# DOC_PARSER_STRAIGHTEN_PAGES=false

# --- OCR Tesseract ---
# DOC_PARSER_OCR_LANG=por
# DOC_PARSER_TESSERACT_CONFIG=--oem 1 --psm 3

# --- Post-processing ---
# Can be overridden per request via query params
# DOC_PARSER_OCR_POSTPROCESS=true
# DOC_PARSER_OCR_FIX_ERRORS=true

# --- Reading Order ---
# Vertical tolerance (0-1) for grouping blocks in the same row.
# Increase if text at similar heights is being split; decrease if
# unrelated blocks are merged together.
# DOC_PARSER_READING_ORDER_Y_TOLERANCE=0.008

# --- Parallelization ---
# DOC_PARSER_PARALLEL_ENABLED=true
# DOC_PARSER_PARALLEL_WORKERS=     # empty = auto (cpu_count)

# --- Searchable PDF ---
# DOC_PARSER_SEARCHABLE_PDF=true

# --- Debug ---
# DOC_PARSER_VERBOSE=true

# --- Directories ---
# DOC_PARSER_OUTPUT_DIR=/app/output

# =============================================================================
# Celery Async Jobs
# =============================================================================

# Redis broker and backend for Celery
# DOC_PARSER_CELERY_BROKER_URL=redis://localhost:6379/0
# DOC_PARSER_CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Number of Celery workers
# DOC_PARSER_CELERY_WORKERS=2

# Celery serialization and timeouts
# DOC_PARSER_CELERY_TASK_SERIALIZER=pickle
# DOC_PARSER_CELERY_RESULT_SERIALIZER=pickle
# DOC_PARSER_CELERY_TASK_TIME_LIMIT=3600  # 1 hour
# DOC_PARSER_CELERY_TASK_SOFT_TIME_LIMIT=3000  # 50 minutes

# =============================================================================
# MongoDB
# =============================================================================

# MongoDB connection URI
# DOC_PARSER_MONGODB_URI=mongodb://admin:admin123@localhost:27017
# DOC_PARSER_MONGODB_DB=caseiro_docs

# Enable vector search (MongoDB 6.0+)
# DOC_PARSER_MONGODB_USE_VECTORS=true

# =============================================================================
# Embeddings (OpenAI-compatible API)
# =============================================================================

# Ollama (default)
# DOC_PARSER_EMBEDDINGS_URL=http://localhost:11434/api/generate
# DOC_PARSER_EMBEDDINGS_MODEL=nomic-embed-text
# DOC_PARSER_EMBEDDINGS_API_KEY=ollama

# Llama.cpp
# DOC_PARSER_EMBEDDINGS_URL=http://localhost:8080/v1/embeddings
# DOC_PARSER_EMBEDDINGS_MODEL=mxbai-embed-large
# DOC_PARSER_EMBEDDINGS_API_KEY=ollama

# Embeddings batch size
# DOC_PARSER_EMBEDDINGS_BATCH_SIZE=1

# =============================================================================
# Webhooks
# =============================================================================

# Webhook URL for job notifications
# DOC_PARSER_WEBHOOK_URL=https://example.com/webhook

# Webhook authentication token
# DOC_PARSER_WEBHOOK_AUTH_TOKEN=your-secret-token

# Webhook settings
# DOC_PARSER_WEBHOOK_MAX_RETRIES=3
# DOC_PARSER_WEBHOOK_TIMEOUT=30

# =============================================================================
# File Size Limits
# =============================================================================

# Maximum file size in MB
# DOC_PARSER_MAX_FILE_SIZE=50
